QDRANT_URL=http://localhost:6333 # Qdrant base URL

# Embedding provider: ollama | openai | claude (default: ollama)
EMBEDDING_PROVIDER=ollama # ollama | openai | claude
EMBEDDING_MODEL=qwen3-embedding:8b # Ollama embedding model

# Agent (LLM) – e.g. Ollama base URL and chat model
AGENT_BASE_URL=http://localhost:11434 # Ollama base URL (use /v1 for OpenAI-compatible when using pi)
AGENT_MODEL=qwen2.5-coder:32b
AGENT_LLM_HEADERS_TIMEOUT_MS=120000 # 2 minutes

# LLM provider: ollama (direct) | pi (@mariozechner/pi-ai, multi-provider + native tool calling)
AGENT_LLM_PROVIDER=ollama

# Use pi-agent-core for the agent loop (1) or custom ReAct loop (0). Requires AGENT_LLM_PROVIDER=pi.
AGENT_USE_PI_AGENT=0

# Kanban: run agent on next todo card every N ms (default 30 min). Set to 1 to enable.
# KANBAN_SCHEDULER_ENABLED=0
# KANBAN_SCHEDULER_INTERVAL_MS=1800000